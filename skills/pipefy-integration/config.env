# Pipefy Integration — Default Configuration
# Override in project .env or shell env

# Playwright flags (for the rare UI-only operations)
PLAYWRIGHT_FLAGS="--workers=1 --reporter=list --timeout=120000 --headed"

# Browser profile path (persistent login session)
PIPEFY_BROWSER_PROFILE="_opensquad/_browser_profile"

# API delay between mutations (ms) - respect rate limits
PIPEFY_API_DELAY_MS=500
