# Pipefy Integration — Default Configuration
# Override in project .env or shell env

# Playwright flags (for the rare UI-only operations)
PLAYWRIGHT_FLAGS="--workers=1 --reporter=list --timeout=120000 --headed"

# Browser profile path (persistent login session)
PIPEFY_BROWSER_PROFILE="_opensquad/_browser_profile"

# Default browser/device for launchPipefyContext() helper
# Override: PIPEFY_BROWSER_HEADLESS=true|false, PIPEFY_BROWSER_WIDTH/HEIGHT, or PIPEFY_BROWSER_DEVICE
# Device presets: "Desktop Chrome", "Desktop Chrome HiDPI", "Desktop Firefox", "Desktop Safari",
#                 "Pixel 7", "iPhone 13", "iPad Pro 11 landscape", etc. (see Playwright devices list)
PIPEFY_BROWSER_HEADLESS=false
PIPEFY_BROWSER_WIDTH=1400
PIPEFY_BROWSER_HEIGHT=900
# PIPEFY_BROWSER_DEVICE="Desktop Chrome"   # uncomment to use a named device preset

# API delay between mutations (ms) - respect rate limits
PIPEFY_API_DELAY_MS=500
