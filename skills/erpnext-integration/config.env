# erpnext-integration — defaults (overridable por .env do projeto ou shell env)

# Caminho absoluto do repo frappe_docker (fork nxz)
# Esta var é lida pela skill para encontrar nxz/.env, nxz/.secrets/, scripts nxz/*.sh
FRAPPE_DOCKER_PATH=/home/walterfrey/Documentos/code/frappe_docker

# Site base (sempre o mesmo conforme access-contract.md)
FRAPPE_SITE=erpnext.localhost

# Usuário alvo default (Administrator para quick start; trocar para email@nxz.ai em runs futuras)
FRAPPE_USER=Administrator

# Delay entre POSTs (ms) — proteger MariaDB dev local
FRAPPE_API_DELAY_MS=300

# Rate de retry em caso de 5xx (dev local pode sobrecarregar)
FRAPPE_MAX_RETRIES=2
FRAPPE_RETRY_BACKOFF_MS=1000

# Override de porta (normalmente vem do frappe_docker/nxz/.env — use override aqui apenas para testes)
# HTTP_PUBLISH_PORT=8090
