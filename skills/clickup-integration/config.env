# ClickUp Integration — Playwright runner defaults
#
# This file is sourced by scripts/run-playwright.sh before anything else.
# It ships as the baseline config for the skill. Users override per-project
# by setting the same variable in their project's .env, or per-run by passing
# flags after `--` on the command line.
#
# Resolution order (later wins):
#   1. This file (skill default)
#   2. Project .env (user default)
#   3. PLAYWRIGHT_FLAGS env var in current shell
#   4. CLI flags after `--`

# Space-separated Playwright test flags. Applied to every run unless overridden.
PLAYWRIGHT_FLAGS="--workers=1 --reporter=list --timeout=120000 --headed"

# Path to the persistent browser profile, relative to the project root.
# Override if your squad keeps sessions elsewhere.
CLICKUP_BROWSER_PROFILE="_opensquad/_browser_profile"
